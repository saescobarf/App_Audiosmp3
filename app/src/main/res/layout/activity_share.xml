<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/share_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FDF5F7">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Compartir con..."
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="100dp"    android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:id="@+id/option_facebook"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="15dp">
        <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/fcb"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="20dp" android:text="Facebook" android:textStyle="bold" android:textSize="18sp" android:textColor="#000000" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/option_whatsapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="15dp">
        <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/wsp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="20dp" android:text="WhatsApp" android:textStyle="bold" android:textSize="18sp" android:textColor="#000000" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/option_x"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="15dp">
        <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/twit"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="20dp" android:text="X" android:textStyle="bold" android:textSize="18sp" android:textColor="#000000" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/option_instagram"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="15dp">
        <ImageView android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/insta"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="20dp" android:text="Instagram" android:textStyle="bold" android:textSize="18sp" android:textColor="#000000" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_back_share"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="20dp"
        android:scaleType="fitCenter"
        android:background="@android:color/transparent"
        android:src="@drawable/back" />

</LinearLayout>